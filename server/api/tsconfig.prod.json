{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "../../",
    "outDir": "dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "target": "es2022",
    "verbatimModuleSyntax": false,
    "baseUrl": "./",
    "paths": {
      "*": ["*"]
    }
  },
  "include": ["src/**/*.ts", "src/types/**/*.ts", "../../shared/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/tests/**/*.ts", "node_modules"]
}
